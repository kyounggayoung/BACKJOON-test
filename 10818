#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>
#include <stdlib.h>

int main()
{
	int n, cnt, x;
	int *num;

	scanf("%d", &n);

	num = (int *)malloc(sizeof(int) * n);

	for (int i = 0; i < n; i++) {
		int a;
		scanf("%d", &a);
		num[i] = a;
	}

	int min = num[0];
	int max = num[0];

	for (int i = 1; i < n; i++) {
		if (num[i] < min) {
			min = num[i];
		}
		if (num[i] > max) {
			max = num[i];
		}
	}

	printf("%d %d", min, max);

	return 0;
}
