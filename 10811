#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
	int n, m;
	scanf("%d %d", &n, &m);
	int *list = (int *)malloc(sizeof(int)*n);
	int *tmp = (int *)malloc(sizeof(int)*n);

	for (int a = 0; a < n; a++) {
		list[a] = a + 1;
		tmp[a] = a + 1;
	}


	for (int a = 0; a < m; a++) {
		int i, j;
		scanf("%d %d", &i, &j);
		for (int b = 0; b <= j - i; b++) {
			list[i - 1 + b] = tmp[j - b - 1];
		}
		for (int c = 0; c < n; c++) {
			tmp[c] = list[c];
		}

	}
	//2 1 3 4 5
	//2 1 4 3 5
	//3 4 1 2 5

	for (int a = 0; a < n; a++) {
		printf("%d ", list[a]);
	}

	free(list);
	free(tmp);
	return 0;
}
