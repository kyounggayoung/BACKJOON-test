#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>
#include <stdlib.h>

int main()
{
	int *num;

	//scanf("%d", &n);

	num = (int *)malloc(sizeof(int) * 9);

	for (int i = 0; i < 9; i++) {
		int a;
		scanf("%d", &a);
		num[i] = a;
	}

	//int min = num[0];
	int max = num[0];
	int maxidx = 0;

	for (int i = 1; i < 9; i++) {
		if (num[i] > max) {
			max = num[i];
			maxidx = i;
		}
	}

	printf("%d\n", max);
	printf("%d", maxidx+1);

	return 0;
}
