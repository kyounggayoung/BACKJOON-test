#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int main() {
	int n, m, i, j;
	scanf("%d %d", &n, &m);
	int *list = (int *)malloc(sizeof(int)*n);

	for (int a = 0; a < n; a++) {
		list[a] = a+1;
	}

	for (int a = 0; a < m; a++) {
		scanf("%d %d", &i, &j);
		int x, y;
		x = list[i - 1];
		y = list[j - 1];
		list[i - 1] = y;
		list[j - 1] = x;
	}

	for (int a = 0; a < n; a++) {
		printf("%d ", list[a]);
	}

	return 0;
}
