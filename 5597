#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int main() {
	int n[31] = { 0 };
	int nx[2];
	int a = 0;

	for (int i = 0; i < 28; i++) {
		int x;
		scanf("%d", &x);
		n[x-1] = 1;
	}

	for (int j = 1; j <= 30; j++) {
		if (n[j-1] == 0) {
			nx[a] = j;
			a++;
		}
	}

	printf("%d\n", nx[0]);
	printf("%d", nx[1]);

	return 0;
}
