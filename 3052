#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int main() {
	int n[10];

	for (int i = 0; i < 10; i++) {
		int x;
		scanf("%d", &x);
		n[i] = x % 42;
	}

	int cnt = 0;
	int fnd = 0;
	int nx[10];
	int a = 0;

	for (int i = 0; i < 10; i++) {
		fnd = 0; //다르면 1
		for (int k = 0; k < a; k++) {
			if (nx[k] == n[i]) {
				fnd = 1;
				break;
			}
		}
		if (fnd == 0) {
			cnt++;
			nx[a] = n[i];
			a++;
		}
	}

	printf("%d", cnt);


	return 0;
}
