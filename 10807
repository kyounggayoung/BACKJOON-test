#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>
#include <stdlib.h>

int main()
{
	int n, cnt, v;
	int *num;
	scanf("%d", &n);

	num = (int *)malloc(sizeof(int) * n);

	for (int i = 0; i < n; i++) {
		int a;
		scanf("%d", &a);
		num[i] = a;
	}

	scanf("%d", &v);

	cnt = 0;

	for (int i = 0; i < n; i++) {
		if (num[i] == v) {
			cnt++;
		}
	}

	printf("%d", cnt);
	return 0;
}
