#include <stdio.h>

int main() {
	int a, b;
	int c;
	scanf("%d %d %d", &a, &b, &c);
	
	int s = 0;
	
	if (a == b && b == c) {
		s += 10000;
		s += a * 1000;
	}
	else if (a == b && a!=c) {
		s += 1000;
		s += a * 100;
	}
	else if (a == c && a != b) {
		s += 1000;
		s += a * 100;
	}
	else if (c == b && a != c) {
		s += 1000;
		s += b * 100;
	}
	else {
		if ((a > b && b > c) || (a > c && c > b)) {
			s += a * 100;
		}
		else if ((b > a && a > c) || (b > c && c > a)) {
			s += b * 100;
		}
		else if ((c > a && a > b) || (c > b && b > a)) {
			s += c * 100;
		}
	}
	printf("%d", s);
	return 0;
}
