#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>
#include <stdlib.h>

int main()
{
	int n, m;
	int *num;

	scanf("%d %d", &n, &m);

	num = (int *)malloc(sizeof(int) * n);

	for(int i = 0; i < n; i++) {
		num[i] = 0;
	}

	for (int a = 0; a < m; a++) {
		int i, j, k;
		scanf("%d %d %d", &i, &j, &k);
		for (int b = i - 1; b < j; b++) {
			num[b] = k;
		}
	}

	for (int i = 0; i < n; i++) {
		printf("%d ", num[i]);
	}

	free(num);

	return 0;
}
