#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>
#include <stdlib.h>

int main()
{
	int n, cnt, x;
	int *num;

	scanf("%d %d", &n, &x);

	num = (int *)malloc(sizeof(int) * n);

	for (int i = 0; i < n; i++) {
		int a;
		scanf("%d", &a);
		num[i] = a;
	}

	for (int i = 0; i < n; i++) {
		if (num[i] < x) {
			printf("%d ", num[i]);
		}
	}

	return 0;
}
